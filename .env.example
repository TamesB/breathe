# Supabase project credentials (Project Settings -> API).
# Copy this file to .env.local and fill in your values.
# Leave these unset to run the app fully in guest mode (localStorage only).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Auth redirect after magic link / Google (required on Vercel; use http://localhost:5173 locally)
VITE_SITE_URL=
